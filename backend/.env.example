# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=замените-на-случайную-строку-50-символов
DEBUG=False
ALLOWED_HOSTS=ваш-ip-или-домен,www.ваш-домен

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=salesdb
DB_USER=salesuser
DB_PASSWORD=сложный-пароль
DB_HOST=localhost
DB_PORT=5432

# ── CORS (адрес фронтенда) ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://ваш-ip-или-домен:3000,http://ваш-ip-или-домен

# ── Redis (кеширование) ───────────────────────────────────────────────────────
# Оставьте пустым для локальной разработки (используется LocMemCache)
REDIS_URL=redis://localhost:6379/1

# ── Media (загруженные файлы) ─────────────────────────────────────────────
# Вынести за пределы проекта — не будет сбрасываться при обновлении
MEDIA_ROOT=/var/www/sales-media
